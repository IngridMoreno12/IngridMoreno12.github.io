---
import BaseHead from '../components/BaseHead.astro';
import BlogTopNav from '../components/blog/BlogTopNav.astro';
import { getThemePalette } from '../data/site';

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;
const palette = await getThemePalette();
---

<!doctype html>
<html lang={lang === 'pt' ? 'pt-BR' : lang} data-palette={palette}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <BlogTopNav />
    <slot />
  </body>
</html>
