---
const currentLang = Astro.url.searchParams.get('lang') || 'en';
const nextLang = currentLang === 'pt' ? 'en' : 'pt';

// SEMPRE incluir o parâmetro lang, para ambos os idiomas
const toggleHref = `${Astro.url.pathname}?lang=${nextLang}`;

const langLabel = currentLang === 'pt' ? 'EN' : 'PT';

console.log('=== DEBUG ===');
console.log('URL:', Astro.url.href);
console.log('lang PARAM:', Astro.url.searchParams.get('lang'));
console.log('Full URL:', Astro.url.href);
console.log('Search params:', Astro.url.searchParams.toString());


---

<a
  href={toggleHref}
  data-astro-reload
  class="lang-toggle"
  aria-label="Switch language"
>
  {langLabel}
</a>

<style>
  .lang-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .lang-toggle:hover {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
  }
</style>