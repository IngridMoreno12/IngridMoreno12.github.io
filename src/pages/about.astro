---
import { getCollection, render } from 'astro:content';
import BlogArticle from '../layouts/BlogArticle.astro';

const allAbout = await getCollection('about');

const about = allAbout.find(post => post.id.includes('pt'));

if (!about) {
  throw new Error('Missing about in Portuguese');
}

const { Content, headings } = await render(about);
---

<BlogArticle
  post={about}
  headings={headings}
  sidebar={{ enable: false, ...about.data.sidebar }}
>
  <Content />
</BlogArticle>