---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import BlogTopNav from '../../components/blog/BlogTopNav.astro';
import { getSiteConfig } from '../../data/site';

const { site, theme } = await getSiteConfig();

const palette = theme.palette;

const lang = 'pt'

const content = {

pt:{

title:'Habilidades & Certificações',

subtitle:
'Tecnologias, ferramentas e conhecimentos que fazem parte da minha jornada.',

sections:[

{
title:'Dados & Analytics',

skills:[
{name:'SQL',icon:'🗄️'},
{name:'Python',icon:'🐍'},
{name:'PySpark',icon:'⚡'},
{name:'ETL / ELT',icon:'🔄'},
{name:'Análise de Dados',icon:'📊'},
{name:'Visualização de Dados',icon:'📈'},
{name:'Storytelling',icon:'📚'}
]
},

{
title:'Cloud & AWS',

skills:[
{name:'Athena',icon:'☁️'},
{name:'S3',icon:'🪣'},
{name:'Glue ETL',icon:'⚙️'},
{name:'QuickSight',icon:'📊'},
{name:'Step Functions',icon:'🔀'}
]
},

{
title:'Desenvolvimento & Ferramentas',

skills:[
{name:'Git',icon:'🌱'},
{name:'GitHub',icon:'🐙'},
{name:'VS Code',icon:'💻'}
]
},

{
title:'Ferramentas de IA',

skills:[
{name:'ChatGPT',icon:'🤖'},
{name:'Claude',icon:'🧠'},
{name:'GitHub Copilot',icon:'✨'}
]
}

],

certificationsTitle:'Certificações',

certifications:[

{label:'Practitioner - Business Analytics', href:'https://www.credly.com/badges/9a42a7e8-631e-4999-af84-525e28d669dd/linked_in_profile'},
{label:'Practitioner - D&A Foundation', href:'https://www.credly.com/badges/960e8e62-9f67-4b29-ac7d-c13a864dc6c9/linked_in_profile'}
],

learningTitle:'Atualmente explorando',

learning:[

'AWS & Cloud',

'IA aplicada a dados',

'Analytics Engineering'

]

},


};

const pageContent=content[lang];

---

<!doctype html>

<html lang={lang} data-palette={palette}>

<head>

<BaseHead
title={`${pageContent.title} | ${site.title}`}
description={pageContent.subtitle}
/>

<style>

main{
width:min(100%,var(--layout-shell-width));
padding:118px var(--layout-page-gutter);
}

.hero{
margin-bottom:60px;
}

.hero h1{
font-size:clamp(2rem,5vw,4rem);
margin-bottom:12px;
}

.hero p{
max-width:650px;
line-height:1.8;
color:var(--paper-ink-soft);
}

.grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(320px,1fr));

gap:24px;

}

.card{

padding:28px;

border-radius:16px;

border:1px solid var(--paper-line);

background:var(--paper-bg);

}

.card h3{

margin-bottom:22px;

font-size:1.1rem;

}

.skills{

display:flex;

flex-wrap:wrap;

gap:12px;

}

.skill{

display:flex;

align-items:center;

gap:8px;

padding:10px 14px;

border-radius:12px;

background:var(--paper-control);

font-size:.9rem;

transition:.25s;

}

.skill:hover{

transform:translateY(-2px);

background:var(--paper-control-hover);

}

.bottom-section{

margin-top:60px;

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(320px,1fr));

gap:24px;

}

.info-card{

padding:28px;

border-radius:16px;

border:1px solid var(--paper-line);

}

.info-card li{

margin-bottom:12px;

line-height:1.7;

}

</style>

</head>

<body>

<BlogTopNav/>

<main>

<section class="hero">

<h1>{pageContent.title}</h1>

<p>{pageContent.subtitle}</p>

</section>

<div class="grid">

{
pageContent.sections.map(section=>(

<div class="card">

<h3>{section.title}</h3>

<div class="skills">

{
section.skills.map(skill=>(

<div class="skill">

<span>{skill.icon}</span>

{skill.name}

</div>

))
}

</div>

</div>

))
}

</div>

<div class="bottom-section">

<div class="info-card">

<h3>
{pageContent.certificationsTitle}
</h3>

<ul>

{
pageContent.certifications.map(cert=>(

typeof cert === 'string' ? (

<li>{cert}</li>

) : (

<li><a href={cert.href} target="_blank" rel="noopener noreferrer">{cert.label}</a></li>

)

))
}

</ul>

</div>

<div class="info-card">

<h3>
{pageContent.learningTitle}
</h3>

<ul>

{
pageContent.learning.map(item=>(

<li>{item}</li>

))
}

</ul>

</div>

</div>

</main>

<Footer/>

</body>

</html>