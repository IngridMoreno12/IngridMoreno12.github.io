---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<BaseLayout
  title="404 Not Found"
  description="Esta página não foi encontrada, pode ter sido movida ou ainda não foi escrita."
>
  <div class="publication-bg" aria-hidden="true"></div>

  <main class="not-found-shell" aria-labelledby="not-found-title">
    <section class="not-found-panel">

      <p class="not-found-kicker">
        404 Not Found
      </p>

      <h1 id="not-found-title">
        Hum... você não deveria estar vendo isso 👀
      </h1>

      <p class="not-found-copy">
        Mas já que está aqui, conheça as minhas cachorras! <br /><br />
        (Ah, e por favor, me avisa desse erro? 🥺)
      </p>

      <div class="dog-section">

        <figure class="dog-card">

          <img
            src="/dogs.jpg"
            alt="Layla e Banguela"
          />

          <figcaption>
            Layla e Banguela 🐶<br /><br />
            Só com um help da IA para ter uma foto das duas juntas haha 🤗
          </figcaption>

        </figure>

      </div>

      <nav
        class="not-found-actions"
        aria-label="404 page links"
      >

        <a
          class="primary-link"
          href={withBase('/')}
        >
          Voltar para a página inicial
        </a>

        <a
          href={withBase('/projects')}
        >
          Dar uma olhadinha nos projetos
        </a>

      </nav>

    </section>
  </main>

</BaseLayout>

<style>

.not-found-shell {
display:grid;
min-height:calc(100vh - 56px);
place-items:center;
padding-top:116px;
padding-bottom:72px;
}

.not-found-panel {
width:min(100%,860px);
padding:clamp(22px,5vw,56px)
clamp(6px,3vw,18px);
animation:not-found-in 420ms ease both;
}

.not-found-kicker {
margin:0 0 12px;
color:var(--paper-accent);
font-family:var(--font-ui-label);
font-size:.78rem;
font-weight:700;
letter-spacing:.12em;
text-transform:uppercase;
}

h1{
max-width:11em;
margin:0;
font-size:clamp(2.3rem,7vw,4.6rem);
line-height:1.08;
}

.not-found-copy{
max-width:42rem;
margin-top:24px;
color:var(--paper-ink-soft);
line-height:1.86;
}

.dog-section{

margin-top:42px;

}

.dog-title{

margin:0;
font-size:1.2rem;
font-weight:700;

}

.dog-subtitle{

margin-top:10px;
margin-bottom:24px;
color:var(--paper-ink-soft);

}

.dog-card{

overflow:hidden;

max-width:520px;

border-radius:14px;

border:1px solid var(--paper-line);

background:var(--paper-control);

transition:.25s;

}

.dog-card:hover{

transform:translateY(-4px);

}

.dog-card img{

display:block;

width:100%;

height:auto;

}

.dog-card figcaption{

padding:14px;

text-align:center;

font-weight:600;

}

.not-found-actions{

display:flex;
flex-wrap:wrap;
gap:10px;
margin-top:30px;

}

.not-found-actions a{

display:inline-flex;
align-items:center;
justify-content:center;

min-height:42px;

padding:8px 14px;

border:1px solid var(--paper-line);

border-radius:8px;

background:var(--paper-control);

text-decoration:none;

transition:.2s;

}

.not-found-actions a:hover{

transform:translateY(-1px);

background:var(--paper-control-hover);

}

.primary-link{

border-color:
color-mix(
in srgb,
var(--paper-accent) 24%,
var(--paper-line)
);

}

@keyframes not-found-in{

from{
opacity:0;
transform:translateY(10px);
}

to{
opacity:1;
transform:translateY(0);
}

}

@media(max-width:720px){

.not-found-actions{

display:grid;
grid-template-columns:1fr;

}

}

</style>